# ========================================
# CONFIGURACIÓN DE DESARROLLO
# ========================================

# Modo de datos
# - true: Usa mock data (localStorage + datos hardcodeados)
# - false: Conecta con backend real
VITE_USE_MOCK_DATA=true

# Habilitar pagos reales
# - true: Genera links de Mercado Pago reales
# - false: Simula proceso de pago (solo UI)
VITE_ENABLE_REAL_PAYMENTS=false

# API URL
VITE_API_URL=http://localhost:9267/api

# Mercado Pago Public Key
# TEST-xxx para sandbox, APP_USR-xxx para producción
VITE_MP_PUBLIC_KEY=TEST-MOCK-PUBLIC-KEY

# URL pública del sitio
VITE_PUBLIC_URL=http://localhost:8854

# Debugging (auto-habilitado en dev)
VITE_ENABLE_DEBUG=true

# Admin path
VITE_ADMIN_PATH=/admin-passajero1900

# ========================================
# CONFIGURACIÓN DE PRODUCCIÓN (ejemplo)
# ========================================
# Descomentar cuando esté listo para producción:

# VITE_USE_MOCK_DATA=false
# VITE_ENABLE_REAL_PAYMENTS=true
# VITE_API_URL=https://api.passajero1900.com/api
# VITE_MP_PUBLIC_KEY=APP_USR-TuPublicKeyReal
# VITE_PUBLIC_URL=https://passajero1900.com
# VITE_ENABLE_DEBUG=false
